{
  "name": "react-native-alternate-app-icon-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Documentation site for react-native-alternate-app-icon",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "prepublishOnly": "node -e \"console.error('\\nThis folder is the Docusaurus docs site, not the npm library.\\n\\nDocs deploy via GitHub Pages. To publish the package, run from the repo root:\\n  cd ..\\n  bun run build\\n  npm publish\\n'); process.exit(1)\"",
    "docusaurus": "docusaurus",
    "sync-media": "node scripts/sync-media.mjs",
    "start": "node scripts/sync-media.mjs && docusaurus start",
    "build": "node scripts/sync-media.mjs && docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^19.0.0",
    "typescript": "~6.0.2"
  },
  "engines": {
    "node": ">=20.0"
  }
}
