# Publish the LIBRARY from the repo root only:
#   bun run build && npm publish
#
# Do NOT run npm publish from docs/ or example/ — those are dev-only packages.
# Verify contents: npm pack --dry-run

# --- Never publish ---
docs/
example/
assets/
website/
.github/
.git/
node_modules/

# --- Dev tooling & config ---
.npmignore
.gitignore
.gitattributes
.prettierrc
.prettierrc.js
.prettierignore
.eslintrc
.eslintrc.js
.eslintrc.cjs
.eslintignore
.editorconfig
.watchmanconfig
tsconfig.json
tsconfig.*.json
tsconfig.tsbuildinfo
babel.config.js
bunfig.toml
bun.lock
release.config.cjs
post-script.js
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Editor ---
.vscode/
.idea/
*.iml

# --- Native build output (not shipped on npm) ---
android/build/
android/.cxx/
android/.gradle/
**/build/
**/.cxx/
**/.gradle/
**/Pods/
**/*.xcworkspace/
**/*.xcodeproj/
**/DerivedData/

# --- Tests & coverage ---
**/__tests__/
**/__mocks__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
coverage/
.nyc_output/

# --- Repo docs (not the npm package README) ---
CONTRIBUTING.md
CODE_OF_CONDUCT.md

# --- Misc ---
.DS_Store
*.log
*.tgz
.env
.env.*
