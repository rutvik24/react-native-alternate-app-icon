{
  "name": "react-native-alternate-app-icon",
  "version": "0.6.0",
  "description": "High-performance React Native library to change app icon at runtime. Dynamic app icon changer for iOS and Android, built with Nitro Modules.",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "git clean -dfX",
    "release": "semantic-release",
    "build": "bun run typecheck && bob build",
    "codegen": "nitrogen --logLevel=\"debug\" && bun run build && node post-script.js",
    "docs": "cd docs && bun start",
    "docs:build": "cd docs && bun run build",
    "docs:serve": "cd docs && bun run serve",
    "prepublishOnly": "node -e \"const n=require('./package.json').name; if(n!=='react-native-alternate-app-icon'){console.error('Run npm publish from the repo root, not docs/ or example/.'); process.exit(1)}\" && bun run build",
    "publish:npm": "npm pack --dry-run && npm publish"
  },
  "keywords": [
    "react-native",
    "react-native-alternate-app-icon",
    "alternate-app-icon",
    "app-icon",
    "app-icon-changer",
    "change-app-icon",
    "dynamic-app-icon",
    "runtime-app-icon",
    "icon-changer",
    "nitro",
    "nitro-modules",
    "ios",
    "android",
    "typescript"
  ],
  "files": [
    "src",
    "lib",
    "nitrogen",
    "nitro.json",
    "LICENSE",
    "README.md",
    "android/build.gradle",
    "android/fix-prefab.gradle",
    "android/gradle.properties",
    "android/CMakeLists.txt",
    "android/src",
    "ios",
    "app.plugin.js",
    "*.podspec"
  ],
  "workspaces": [
    "example"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rutvik24/react-native-alternate-app-icon.git"
  },
  "author": "rutvik24 <rutviknabhoya2001@gmail.com> (https://github.com/rutvik24)",
  "license": "MIT",
  "bugs": "https://github.com/rutvik24/react-native-alternate-app-icon/issues",
  "homepage": "https://rutvik24.github.io/react-native-alternate-app-icon/",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@jamesacarr/eslint-formatter-github-actions": "^0.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/react": "19.2.0",
    "nitrogen": "0.32.0",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-builder-bob": "^0.40.18",
    "react-native-nitro-modules": "0.32.0",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
